---
import '../styles/global.css';
const year = new Date().getFullYear();
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/debbie-s-dog-food-campaign-website/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content="Debbie's Dog Food — premium nutrition your pup will go wild for. Coming soon!" />
    <title>Debbie's Dog Food — Coming Soon 🐾</title>
  </head>

  <body class="bg-brand-darkbrown overflow-x-hidden font-body">

    <!-- ╔══════════════════════════════════════════════╗
         ║  ANNOUNCEMENT BAR                           ║
         ╚══════════════════════════════════════════════╝ -->
    <div class="relative overflow-hidden bg-gradient-to-r from-brand-red via-brand-orange to-brand-yellow py-2.5 text-center">
      <div class="marquee-track gap-16 items-center whitespace-nowrap text-brand-darkbrown font-extrabold text-sm tracking-wide uppercase">
        {[...Array(8)].map(() => (
          <span class="inline-flex items-center gap-4 pr-16">
            <span>🐾</span><span>Coming Soon</span>
            <span>🦴</span><span>Premium Dog Food</span>
            <span>⭐</span><span>Launching Soon</span>
            <span>🐶</span><span>Join the Waitlist</span>
          </span>
        ))}
      </div>
    </div>


    <!-- ╔══════════════════════════════════════════════╗
         ║  HERO / COMING SOON SECTION                 ║
         ╚══════════════════════════════════════════════╝ -->
    <section class="paw-bg bg-stars relative min-h-screen flex flex-col items-center justify-center px-4 py-20 overflow-hidden">

      <!-- Ambient glow blobs -->
      <div class="pointer-events-none absolute -top-32 -left-32 w-96 h-96 rounded-full bg-brand-orange opacity-20 blur-3xl"></div>
      <div class="pointer-events-none absolute -bottom-32 -right-32 w-[28rem] h-[28rem] rounded-full bg-brand-yellow opacity-15 blur-3xl"></div>
      <div class="pointer-events-none absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[700px] h-[700px] rounded-full bg-brand-red opacity-5 blur-3xl"></div>

      <!-- Spinning starbursts -->
      <div class="pointer-events-none absolute top-10 right-10 w-28 h-28 opacity-30 animate-spin-slow">
        <svg viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
          <polygon points="50,2 61,35 95,35 68,57 79,91 50,70 21,91 32,57 5,35 39,35" fill="#FFD93D"/>
        </svg>
      </div>
      <div class="pointer-events-none absolute bottom-20 left-10 w-20 h-20 opacity-25 animate-spin-slow" style="animation-direction:reverse;animation-duration:9s;">
        <svg viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
          <polygon points="50,2 61,35 95,35 68,57 79,91 50,70 21,91 32,57 5,35 39,35" fill="#FF6B1A"/>
        </svg>
      </div>
      <div class="pointer-events-none absolute top-1/3 left-6 w-14 h-14 opacity-20 animate-spin-slow" style="animation-duration:15s;">
        <svg viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
          <polygon points="50,2 61,35 95,35 68,57 79,91 50,70 21,91 32,57 5,35 39,35" fill="#E63946"/>
        </svg>
      </div>

      <!-- Floating emoji accents -->
      <span class="pointer-events-none select-none absolute top-24 left-[7%]  text-4xl animate-float  opacity-40" style="animation-delay:0s;">🐾</span>
      <span class="pointer-events-none select-none absolute top-40 right-[10%] text-3xl animate-float-slow opacity-30" style="animation-delay:1s;">🐶</span>
      <span class="pointer-events-none select-none absolute bottom-32 left-[14%] text-2xl animate-float  opacity-25" style="animation-delay:0.5s;">🦴</span>
      <span class="pointer-events-none select-none absolute bottom-24 right-[7%]  text-3xl animate-float-slow opacity-35" style="animation-delay:1.8s;">⭐</span>
      <span class="pointer-events-none select-none absolute top-[55%] right-[4%]  text-xl animate-float  opacity-20" style="animation-delay:2.2s;">🐾</span>

      <!-- ── COMING SOON badge ── -->
      <div class="animate-pulse-glow mb-7 inline-flex items-center gap-2 rounded-full border-2 border-brand-yellow bg-brand-yellow/10 px-6 py-2.5 backdrop-blur-sm shadow-xl">
        <span class="h-2.5 w-2.5 rounded-full bg-brand-yellow animate-bounce-sm inline-block"></span>
        <span class="font-body font-extrabold text-brand-yellow tracking-[0.25em] text-xs uppercase">
          Coming Soon
        </span>
        <span class="h-2.5 w-2.5 rounded-full bg-brand-yellow animate-bounce-sm inline-block" style="animation-delay:0.4s;"></span>
      </div>

      <!-- ── Brand Logo / Hero Heading ── -->
      <div class="animate-float mb-4 text-center">

        <!--
          MODERN LOGO LOCKUP
          A geometric shield mark + wordmark with a clean inline SVG icon.
          The mark uses a flat shield silhouette with an abstract dog-head
          formed from simple geometric shapes — no legacy bowl icon.
        -->
        <div class="logo-lockup mx-auto mb-8 flex flex-col items-center gap-0 select-none">

          <!-- ── Shield mark ── -->
          <div class="logo-mark relative mb-5">
            <!-- Outer glow ring -->
            <div class="absolute inset-0 rounded-[2rem] bg-gradient-to-br from-brand-orange/40 to-brand-red/40 blur-xl scale-110 opacity-70 pointer-events-none"></div>

            <svg
              class="relative z-10 drop-shadow-2xl"
              width="120" height="136"
              viewBox="0 0 120 136"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
              aria-label="Debbie's Dog Food shield mark"
            >
              <defs>
                <linearGradient id="shieldGrad" x1="0" y1="0" x2="120" y2="136" gradientUnits="userSpaceOnUse">
                  <stop offset="0%"   stop-color="#FF6B1A"/>
                  <stop offset="55%"  stop-color="#E63946"/>
                  <stop offset="100%" stop-color="#B5222D"/>
                </linearGradient>
                <linearGradient id="shieldGloss" x1="0" y1="0" x2="0" y2="136" gradientUnits="userSpaceOnUse">
                  <stop offset="0%"   stop-color="#FFFFFF" stop-opacity="0.18"/>
                  <stop offset="50%"  stop-color="#FFFFFF" stop-opacity="0"/>
                </linearGradient>
                <linearGradient id="iconGrad" x1="20" y1="30" x2="100" y2="110" gradientUnits="userSpaceOnUse">
                  <stop offset="0%"   stop-color="#FFD93D"/>
                  <stop offset="100%" stop-color="#FF9F00"/>
                </linearGradient>
                <linearGradient id="stripeGrad" x1="0" y1="0" x2="120" y2="0" gradientUnits="userSpaceOnUse">
                  <stop offset="0%"   stop-color="#FFD93D" stop-opacity="0"/>
                  <stop offset="50%"  stop-color="#FFD93D" stop-opacity="0.22"/>
                  <stop offset="100%" stop-color="#FFD93D" stop-opacity="0"/>
                </linearGradient>
              </defs>

              <!-- Shield body -->
              <path
                d="M60 4 L112 22 L112 74 Q112 116 60 132 Q8 116 8 74 L8 22 Z"
                fill="url(#shieldGrad)"
              />
              <!-- Gloss overlay -->
              <path
                d="M60 4 L112 22 L112 74 Q112 116 60 132 Q8 116 8 74 L8 22 Z"
                fill="url(#shieldGloss)"
              />
              <!-- Subtle horizontal stripe -->
              <rect x="8" y="58" width="104" height="18" fill="url(#stripeGrad)" rx="2"/>
              <!-- Shield inner border -->
              <path
                d="M60 12 L104 28 L104 74 Q104 108 60 122 Q16 108 16 74 L16 28 Z"
                fill="none"
                stroke="#FFD93D"
                stroke-width="1.5"
                stroke-opacity="0.35"
              />

              <!-- ── Abstract dog head icon ── -->
              <!-- Head circle -->
              <circle cx="60" cy="62" r="26" fill="url(#iconGrad)"/>
              <!-- Left ear -->
              <ellipse cx="40" cy="46" rx="9" ry="13" fill="#FF9F00" transform="rotate(-18 40 46)"/>
              <!-- Right ear -->
              <ellipse cx="80" cy="46" rx="9" ry="13" fill="#FF9F00" transform="rotate(18 80 46)"/>
              <!-- Ear inner left -->
              <ellipse cx="40" cy="46" rx="5" ry="8" fill="#E63946" transform="rotate(-18 40 46)"/>
              <!-- Ear inner right -->
              <ellipse cx="80" cy="46" rx="5" ry="8" fill="#E63946" transform="rotate(18 80 46)"/>
              <!-- Snout -->
              <ellipse cx="60" cy="72" rx="13" ry="9" fill="#E8A020"/>
              <!-- Nose -->
              <ellipse cx="60" cy="67" rx="5.5" ry="3.5" fill="#3A1F0B"/>
              <!-- Nose shine -->
              <ellipse cx="58" cy="66" rx="1.8" ry="1.2" fill="#FFFFFF" opacity="0.45"/>
              <!-- Left eye -->
              <circle cx="50" cy="57" r="4.5" fill="#3A1F0B"/>
              <circle cx="51.4" cy="55.8" r="1.5" fill="#FFFFFF" opacity="0.6"/>
              <!-- Right eye -->
              <circle cx="70" cy="57" r="4.5" fill="#3A1F0B"/>
              <circle cx="71.4" cy="55.8" r="1.5" fill="#FFFFFF" opacity="0.6"/>

              <!-- Paw accent — bottom-right of shield -->
              <g transform="translate(82, 100)" opacity="0.85">
                <!-- Main pad -->
                <ellipse cx="8" cy="10" rx="5.5" ry="4.5" fill="#FFD93D"/>
                <!-- Top toe pads -->
                <circle cx="3"  cy="5"  r="2.2" fill="#FFD93D"/>
                <circle cx="8"  cy="3.5" r="2.2" fill="#FFD93D"/>
                <circle cx="13" cy="5"  r="2.2" fill="#FFD93D"/>
              </g>
            </svg>
          </div>

          <!-- ── Wordmark ── -->
          <div class="logo-wordmark flex flex-col items-center gap-1">
            <!-- Brand name -->
            <h1 class="font-display leading-none tracking-tight drop-shadow-2xl" style="font-size: clamp(3rem, 10vw, 5.5rem);">
              <span class="text-gradient-fire">Debbie's</span>
            </h1>

            <!-- "DOG FOOD" pill tag -->
            <div class="logo-tag inline-flex items-center gap-3 mt-1">
              <!-- Left rule -->
              <span class="block h-px w-10 bg-gradient-to-r from-transparent to-brand-yellow/70 sm:w-14"></span>
              <!-- Tag pill -->
              <span
                class="inline-flex items-center gap-1.5 rounded-full border border-brand-yellow/50 bg-brand-yellow/10 px-4 py-1 backdrop-blur-sm"
              >
                <svg width="12" height="12" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <ellipse cx="8" cy="10" rx="5" ry="4" fill="#FFD93D" opacity="0.9"/>
                  <circle cx="4"  cy="5.5" r="2.2" fill="#FFD93D" opacity="0.9"/>
                  <circle cx="8"  cy="4"   r="2.2" fill="#FFD93D" opacity="0.9"/>
                  <circle cx="12" cy="5.5" r="2.2" fill="#FFD93D" opacity="0.9"/>
                </svg>
                <span class="font-display text-brand-yellow text-base sm:text-lg md:text-xl tracking-[0.2em]">DOG FOOD</span>
                <svg width="12" height="12" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <ellipse cx="8" cy="10" rx="5" ry="4" fill="#FFD93D" opacity="0.9"/>
                  <circle cx="4"  cy="5.5" r="2.2" fill="#FFD93D" opacity="0.9"/>
                  <circle cx="8"  cy="4"   r="2.2" fill="#FFD93D" opacity="0.9"/>
                  <circle cx="12" cy="5.5" r="2.2" fill="#FFD93D" opacity="0.9"/>
                </svg>
              </span>
              <!-- Right rule -->
              <span class="block h-px w-10 bg-gradient-to-l from-transparent to-brand-yellow/70 sm:w-14"></span>
            </div>
          </div>
        </div>

      </div>

      <!-- Tagline -->
      <p class="mt-5 mb-3 font-body font-semibold text-brand-cream/90 text-lg sm:text-xl md:text-2xl text-center max-w-xl leading-snug">
        Premium nutrition your pup will go <span class="text-brand-yellow font-extrabold">absolutely wild</span> for. 🐾
      </p>
      <p class="mb-12 text-brand-cream/55 font-body text-sm sm:text-base text-center max-w-md leading-relaxed">
        We're whipping up something amazing in the kitchen. Be the first to know
        when we launch — drop your details below!
      </p>

      <!-- ─────────────────────────────────────────
           SIGN-UP FORM CARD
      ───────────────────────────────────────── -->
      <div id="signup" class="w-full max-w-md">
        <div class="relative rounded-3xl border border-brand-orange/30 bg-white/5 backdrop-blur-md shadow-2xl p-8 sm:p-10 overflow-hidden">
          <!-- Inner rim glow -->
          <div class="pointer-events-none absolute inset-0 rounded-3xl ring-1 ring-inset ring-white/10"></div>
          <!-- Card corner glow -->
          <div class="pointer-events-none absolute -top-12 -right-12 w-48 h-48 rounded-full bg-brand-orange/20 blur-2xl"></div>
          <div class="pointer-events-none absolute -bottom-10 -left-10 w-36 h-36 rounded-full bg-brand-yellow/10 blur-2xl"></div>

          <h2 class="font-display text-2xl sm:text-3xl text-brand-yellow text-center mb-1">
            Get Early Access
          </h2>
          <p class="text-brand-cream/55 text-sm text-center mb-8">
            Join the pack — be first to hear when we launch! 🐶
          </p>

          <!-- Success state (hidden by default) -->
          <div id="success-msg" class="hidden flex-col items-center justify-center py-8 text-center gap-4">
            <div class="text-6xl animate-bounce-sm">🎉</div>
            <p class="font-display text-brand-yellow text-2xl">You're on the list!</p>
            <p class="text-brand-cream/70 text-sm leading-relaxed max-w-xs">
              We'll bark at you the moment we launch. Get ready for something delicious!
            </p>
          </div>

          <form id="signup-form" novalidate class="flex flex-col gap-5">

            <!-- First Name field -->
            <div class="flex flex-col gap-1.5">
              <label for="firstName" class="text-brand-cream/80 font-body font-bold text-xs tracking-widest uppercase">
                First Name
              </label>
              <div class="relative">
                <span class="pointer-events-none select-none absolute left-3.5 top-1/2 -translate-y-1/2 text-lg text-brand-orange/70">🐶</span>
                <input
                  type="text"
                  id="firstName"
                  name="firstName"
                  placeholder="e.g. Debbie"
                  autocomplete="given-name"
                  required
                  class="w-full rounded-xl bg-white/10 border border-white/15 text-brand-cream placeholder-brand-cream/30 font-body text-base pl-10 pr-4 py-3.5 outline-none transition-all duration-200 focus:border-brand-orange focus:ring-2 focus:ring-brand-orange/40 hover:border-white/30"
                />
              </div>
              <p id="firstName-error" class="hidden text-brand-red text-xs font-bold ml-1">
                Please enter your first name.
              </p>
            </div>

            <!-- Email field -->
            <div class="flex flex-col gap-1.5">
              <label for="email" class="text-brand-cream/80 font-body font-bold text-xs tracking-widest uppercase">
                Email Address
              </label>
              <div class="relative">
                <span class="pointer-events-none select-none absolute left-3.5 top-1/2 -translate-y-1/2 text-lg text-brand-orange/70">📧</span>
                <input
                  type="email"
                  id="email"
                  name="email"
                  placeholder="you@example.com"
                  autocomplete="email"
                  required
                  class="w-full rounded-xl bg-white/10 border border-white/15 text-brand-cream placeholder-brand-cream/30 font-body text-base pl-10 pr-4 py-3.5 outline-none transition-all duration-200 focus:border-brand-orange focus:ring-2 focus:ring-brand-orange/40 hover:border-white/30"
                />
              </div>
              <p id="email-error" class="hidden text-brand-red text-xs font-bold ml-1">
                Please enter a valid email address.
              </p>
            </div>

            <!-- Submit button -->
            <button
              type="submit"
              class="btn-shimmer mt-2 w-full rounded-xl py-4 font-display text-white text-xl tracking-wide shadow-xl hover:scale-[1.03] active:scale-[0.97] transition-transform duration-150 focus:outline-none focus:ring-4 focus:ring-brand-yellow/50 cursor-pointer"
            >
              Count Me In! 🐾
            </button>

            <p class="text-brand-cream/35 text-xs text-center leading-relaxed">
              No spam, ever. Unsubscribe any time.<br/>We're dog people — we keep it real. 🐕
            </p>
          </form>
        </div>

        <!-- Trust badges -->
        <div class="mt-5 flex flex-wrap items-center justify-center gap-4">
          <span class="inline-flex items-center gap-1.5 rounded-full bg-white/5 border border-white/10 px-3.5 py-1.5 text-brand-cream/60 text-xs font-semibold">
            🔒 100% Private
          </span>
          <span class="inline-flex items-center gap-1.5 rounded-full bg-white/5 border border-white/10 px-3.5 py-1.5 text-brand-cream/60 text-xs font-semibold">
            🎁 Early-Bird Perks
          </span>
          <span class="inline-flex items-center gap-1.5 rounded-full bg-white/5 border border-white/10 px-3.5 py-1.5 text-brand-cream/60 text-xs font-semibold">
            🐾 8,400+ on Waitlist
          </span>
        </div>
      </div>

      <!-- Scroll hint -->
      <div class="mt-14 flex flex-col items-center gap-2 animate-bounce-sm text-brand-cream/40">
        <span class="text-xs uppercase tracking-widest font-semibold">Discover More</span>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
        </svg>
      </div>
    </section>


    <!-- ╔══════════════════════════════════════════════╗
         ║  FEATURE CARDS                              ║
         ╚══════════════════════════════════════════════╝ -->
    <section class="relative bg-brand-brown py-24 px-4 overflow-hidden">
      <!-- Subtle dot grid -->
      <div class="pointer-events-none absolute inset-0 opacity-50"
           style="background-image:radial-gradient(circle, rgba(255,107,26,0.12) 1px, transparent 1px); background-size:36px 36px;"></div>

      <div class="relative max-w-5xl mx-auto">
        <div class="text-center mb-14">
          <span class="inline-flex items-center gap-2 rounded-full border border-brand-yellow/30 bg-brand-yellow/5 px-4 py-1.5 text-brand-yellow/80 text-xs font-extrabold uppercase tracking-widest mb-5">
            🌟 Why Debbie's?
          </span>
          <h2 class="font-display text-3xl sm:text-4xl md:text-5xl text-gradient-fire mb-3">
            Why Dogs Can't Resist Us
          </h2>
          <p class="text-brand-cream/55 max-w-xl mx-auto text-sm sm:text-base leading-relaxed">
            Every bag is packed with tail-wagging goodness — here's what makes us different.
          </p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
          {[
            { icon: "🥩", title: "Real Meat First",         body: "Cage-free chicken, wild salmon & grass-fed beef. No fillers, no nonsense — ever." },
            { icon: "🌿", title: "All-Natural Ingredients",  body: "Zero artificial colours, flavours or preservatives. Just wholesome, clean goodness." },
            { icon: "🔬", title: "Vet-Formulated",           body: "Developed alongside veterinary nutritionists for optimal lifelong canine health." },
            { icon: "📦", title: "Delivered to You",         body: "Flexible subscriptions with free delivery, fresh to your door every single month." },
          ].map(card => (
            <div class="group flex flex-col items-center text-center bg-white/5 hover:bg-white/10 border border-white/10 hover:border-brand-orange/50 rounded-2xl p-6 transition-all duration-300 hover:-translate-y-2 hover:shadow-2xl cursor-default">
              <div class="text-5xl mb-4 group-hover:animate-bounce-sm select-none">{card.icon}</div>
              <h3 class="font-display text-brand-yellow text-lg mb-2">{card.title}</h3>
              <p class="text-brand-cream/55 text-sm leading-relaxed">{card.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ╔══════════════════════════════════════════════╗
         ║  SOCIAL PROOF / NUMBERS                     ║
         ╚══════════════════════════════════════════════╝ -->
    <section class="paw-bg py-24 px-4">
      <div class="max-w-4xl mx-auto text-center">
        <span class="inline-flex items-center gap-2 rounded-full border border-brand-yellow/30 bg-brand-yellow/5 px-4 py-1.5 text-brand-yellow/80 text-xs font-extrabold uppercase tracking-widest mb-6">
          🔥 The Buzz Is Real
        </span>
        <h2 class="font-display text-3xl sm:text-4xl md:text-5xl text-brand-cream mb-16">
          Dogs Already Love Us
        </h2>

        <!-- Stats row -->
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 mb-20">
          {[
            { stat: "8,400+", label: "Dogs on the Waitlist", grad: "text-gradient-fire" },
            { stat: "100%",   label: "Natural Ingredients",  grad: "text-gradient-gold" },
            { stat: "5 ⭐",   label: "Beta Taster Rating",   grad: "text-gradient-fire" },
          ].map(s => (
            <div class="flex flex-col items-center gap-1">
              <span class={`font-display text-5xl sm:text-6xl ${s.grad}`}>{s.stat}</span>
              <span class="text-brand-cream/55 font-semibold text-xs uppercase tracking-widest">{s.label}</span>
            </div>
          ))}
        </div>

        <!-- Testimonial cards -->
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-5">
          {[
            {
              quote: "Biscuit used to be a picky eater. Now she practically knocks the bowl over she's so excited. Unreal.",
              name: "Sarah M.",
              role: "Golden Retriever Mum 🐕",
              initials: "S",
              grad: "from-brand-orange to-brand-red",
              textCol: "text-white",
            },
            {
              quote: "My vet actually asked what I'd changed. Coat is glossier, energy through the roof. Debbie's is it.",
              name: "James T.",
              role: "Beagle Dad 🐶",
              initials: "J",
              grad: "from-brand-yellow to-brand-orange",
              textCol: "text-brand-darkbrown",
            },
            {
              quote: "Three dogs. Three breeds. All three obsessed. I've never seen anything like it. Launch already!",
              name: "Priya K.",
              role: "Multi-dog Household 🐾🐾🐾",
              initials: "P",
              grad: "from-brand-red to-brand-orange",
              textCol: "text-white",
            },
          ].map(t => (
            <div class="relative bg-white/5 border border-white/10 rounded-2xl p-6 text-left hover:border-brand-yellow/30 transition-colors duration-300">
              <div class="text-brand-yellow text-base mb-3 tracking-tight">★★★★★</div>
              <p class="text-brand-cream/80 text-sm leading-relaxed mb-5 italic">"{t.quote}"</p>
              <div class="flex items-center gap-3">
                <div class={`w-9 h-9 rounded-full bg-gradient-to-br ${t.grad} flex items-center justify-center font-display ${t.textCol} text-sm shrink-0`}>
                  {t.initials}
                </div>
                <div>
                  <p class="text-brand-cream font-bold text-sm">{t.name}</p>
                  <p class="text-brand-cream/40 text-xs">{t.role}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ╔══════════════════════════════════════════════╗
         ║  SECOND CTA BANNER                          ║
         ╚══════════════════════════════════════════════╝ -->
    <section class="relative bg-gradient-to-r from-brand-orange via-brand-red to-brand-orange py-20 px-4 overflow-hidden">
      <!-- Dot overlay -->
      <div class="pointer-events-none absolute inset-0"
           style="background-image:radial-gradient(circle, rgba(255,255,255,0.07) 1px, transparent 1px); background-size:50px 50px;"></div>
      <!-- Glowing blobs -->
