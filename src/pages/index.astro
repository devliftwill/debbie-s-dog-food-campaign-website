---
import '../styles/global.css';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content="Debbie's Dog Food — premium nutrition your pup will go wild for. Coming soon!" />
    <title>Debbie's Dog Food — Coming Soon 🐾</title>
  </head>

  <body class="font-body bg-brand-darkbrown overflow-x-hidden">

    <!-- ═══════════════════════════════════════════
         HERO / COMING SOON SECTION
    ════════════════════════════════════════════ -->
    <section class="paw-bg bg-stars relative min-h-screen flex flex-col items-center justify-center px-4 py-16 overflow-hidden">

      <!-- Decorative blobs -->
      <div class="pointer-events-none absolute -top-20 -left-20 w-72 h-72 rounded-full bg-brand-orange opacity-20 blur-3xl"></div>
      <div class="pointer-events-none absolute -bottom-20 -right-20 w-96 h-96 rounded-full bg-brand-yellow opacity-15 blur-3xl"></div>
      <div class="pointer-events-none absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] rounded-full bg-brand-red opacity-5 blur-3xl"></div>

      <!-- Spinning starburst ring (decorative) -->
      <div class="pointer-events-none absolute top-10 right-10 w-24 h-24 opacity-30 animate-spin-slow">
        <svg viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
          <polygon points="50,2 61,35 95,35 68,57 79,91 50,70 21,91 32,57 5,35 39,35" fill="#FFD93D"/>
        </svg>
      </div>
      <div class="pointer-events-none absolute bottom-16 left-10 w-16 h-16 opacity-20 animate-spin-slow" style="animation-direction: reverse;">
        <svg viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
          <polygon points="50,2 61,35 95,35 68,57 79,91 50,70 21,91 32,57 5,35 39,35" fill="#FF6B1A"/>
        </svg>
      </div>

      <!-- Floating paw emoji accents -->
      <span class="pointer-events-none absolute top-20 left-[8%] text-3xl animate-float opacity-40 select-none">🐾</span>
      <span class="pointer-events-none absolute top-36 right-[12%] text-2xl animate-float-slow opacity-30 select-none" style="animation-delay:1s;">🐶</span>
      <span class="pointer-events-none absolute bottom-28 left-[15%] text-xl animate-float opacity-25 select-none" style="animation-delay:0.5s;">🦴</span>
      <span class="pointer-events-none absolute bottom-20 right-[8%] text-2xl animate-float-slow opacity-35 select-none" style="animation-delay:1.5s;">⭐</span>

      <!-- COMING SOON badge -->
      <div class="animate-pulse-glow mb-6 inline-flex items-center gap-2 rounded-full border-2 border-brand-yellow bg-brand-yellow/10 px-5 py-2 backdrop-blur-sm">
        <span class="h-2.5 w-2.5 rounded-full bg-brand-yellow animate-bounce-sm inline-block"></span>
        <span class="font-body font-800 text-brand-yellow tracking-[0.2em] text-xs uppercase font-extrabold">
          Coming Soon
        </span>
        <span class="h-2.5 w-2.5 rounded-full bg-brand-yellow animate-bounce-sm inline-block" style="animation-delay: 0.3s;"></span>
      </div>

      <!-- Logo / Brand wordmark -->
      <div class="animate-float mb-4 text-center">
        <!-- Dog bowl icon -->
        <div class="mx-auto mb-4 flex items-center justify-center w-24 h-24 rounded-full bg-gradient-to-br from-brand-orange to-brand-red shadow-2xl border-4 border-brand-yellow/60">
          <svg class="w-14 h-14" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
            <!-- Bowl -->
            <ellipse cx="32" cy="44" rx="22" ry="8" fill="#fff8f0" opacity="0.95"/>
            <path d="M10 40 Q10 56 32 56 Q54 56 54 40 Z" fill="#fff8f0" opacity="0.9"/>
            <!-- Food pieces -->
            <circle cx="26" cy="42" r="3" fill="#FF6B1A"/>
            <circle cx="33" cy="41" r="2.5" fill="#E63946"/>
            <circle cx="39" cy="43" r="2" fill="#FF6B1A"/>
            <!-- Steam -->
            <path d="M24 34 Q26 30 24 26" stroke="#FFD93D" stroke-width="2" stroke-linecap="round" fill="none"/>
            <path d="M32 32 Q34 28 32 24" stroke="#FFD93D" stroke-width="2" stroke-linecap="round" fill="none"/>
            <path d="M40 34 Q42 30 40 26" stroke="#FFD93D" stroke-width="2" stroke-linecap="round" fill="none"/>
            <!-- Paw on bowl -->
            <circle cx="32" cy="38" r="1.2" fill="#5C3317" opacity="0.4"/>
            <circle cx="29" cy="36.5" r="0.9" fill="#5C3317" opacity="0.4"/>
            <circle cx="35" cy="36.5" r="0.9" fill="#5C3317" opacity="0.4"/>
            <circle cx="31" cy="35.2" r="0.8" fill="#5C3317" opacity="0.4"/>
          </svg>
        </div>

        <h1 class="font-display text-gradient-fire text-6xl sm:text-7xl md:text-8xl leading-none drop-shadow-2xl">
          Debbie's
        </h1>
        <div class="flex items-center justify-center gap-3 mt-1">
          <div class="h-px flex-1 max-w-[80px] bg-gradient-to-r from-transparent to-brand-yellow/60"></div>
          <span class="font-display text-gradient-gold text-3xl sm:text-4xl md:text-5xl tracking-widest">
            Dog Food
          </span>
          <div class="h-px flex-1 max-w-[80px] bg-gradient-to-l from-transparent to-brand-yellow/60"></div>
        </div>
      </div>

      <!-- Tagline -->
      <p class="mt-4 mb-3 text-brand-cream/90 font-body font-semibold text-lg sm:text-xl md:text-2xl text-center max-w-xl leading-snug">
        Premium nutrition your pup will go <span class="text-brand-yellow font-extrabold">absolutely wild</span> for. 🐾
      </p>
      <p class="mb-10 text-brand-cream/60 font-body text-sm sm:text-base text-center max-w-md">
        We're whipping up something amazing in the kitchen. Be the first to know when we launch — drop your details below!
      </p>

      <!-- ══════════════════════════════
           SIGN-UP FORM CARD
      ═══════════════════════════════ -->
      <div id="signup" class="w-full max-w-md">
        <div class="relative rounded-3xl border border-brand-orange/30 bg-white/5 backdrop-blur-md shadow-2xl p-8 sm:p-10 overflow-hidden">
          <!-- Card inner glow -->
          <div class="pointer-events-none absolute inset-0 rounded-3xl ring-1 ring-inset ring-white/10"></div>
          <div class="pointer-events-none absolute -top-10 -right-10 w-40 h-40 rounded-full bg-brand-orange/20 blur-2xl"></div>

          <h2 class="font-display text-2xl sm:text-3xl text-brand-yellow text-center mb-1">
            Get Early Access
          </h2>
          <p class="text-brand-cream/60 text-sm text-center mb-7">
            Join the pack — be the first to hear about our launch!
          </p>

          <!-- Success message (hidden by default) -->
          <div id="success-msg" class="hidden flex-col items-center justify-center py-6 text-center gap-3">
            <div class="text-5xl animate-bounce-sm">🎉</div>
            <p class="font-display text-brand-yellow text-2xl">You're on the list!</p>
            <p class="text-brand-cream/70 text-sm">We'll bark at you the moment we launch.</p>
          </div>

          <form id="signup-form" novalidate class="flex flex-col gap-5">

            <!-- First Name -->
            <div class="flex flex-col gap-1.5">
              <label for="firstName" class="text-brand-cream/80 font-body font-bold text-sm tracking-wide uppercase">
                First Name
              </label>
              <div class="relative">
                <span class="absolute left-3.5 top-1/2 -translate-y-1/2 text-brand-orange/70 text-lg select-none pointer-events-none">🐶</span>
                <input
                  type="text"
                  id="firstName"
                  name="firstName"
                  placeholder="e.g. Debbie"
                  autocomplete="given-name"
                  required
                  class="w-full rounded-xl bg-white/10 border border-white/15 text-brand-cream placeholder-brand-cream/30 font-body text-base px-4 pl-10 py-3.5 outline-none transition-all duration-200 focus:border-brand-orange focus:ring-2 focus:ring-brand-orange/40 hover:border-white/30"
                />
              </div>
              <p id="firstName-error" class="hidden text-brand-red text-xs font-semibold ml-1">Please enter your first name.</p>
            </div>

            <!-- Email -->
            <div class="flex flex-col gap-1.5">
              <label for="email" class="text-brand-cream/80 font-body font-bold text-sm tracking-wide uppercase">
                Email Address
              </label>
              <div class="relative">
                <span class="absolute left-3.5 top-1/2 -translate-y-1/2 text-brand-orange/70 text-lg select-none pointer-events-none">📧</span>
                <input
                  type="email"
                  id="email"
                  name="email"
                  placeholder="you@example.com"
                  autocomplete="email"
                  required
                  class="w-full rounded-xl bg-white/10 border border-white/15 text-brand-cream placeholder-brand-cream/30 font-body text-base px-4 pl-10 py-3.5 outline-none transition-all duration-200 focus:border-brand-orange focus:ring-2 focus:ring-brand-orange/40 hover:border-white/30"
                />
              </div>
              <p id="email-error" class="hidden text-brand-red text-xs font-semibold ml-1">Please enter a valid email address.</p>
            </div>

            <!-- Submit -->
            <button
              type="submit"
              class="btn-shimmer mt-1 w-full rounded-xl py-4 font-display text-white text-xl tracking-wide shadow-lg hover:scale-[1.03] active:scale-[0.98] transition-transform duration-150 focus:outline-none focus:ring-4 focus:ring-brand-yellow/50 cursor-pointer"
            >
              Count Me In! 🐾
            </button>

            <p class="text-brand-cream/35 text-xs text-center">
              No spam, ever. Unsubscribe any time. We're dog people — we keep it real. 🐕
            </p>
          </form>
        </div>
      </div>

      <!-- Scroll hint -->
      <div class="mt-14 flex flex-col items-center gap-2 animate-bounce-sm text-brand-cream/40">
        <span class="text-xs uppercase tracking-widest font-semibold">Scroll for more</span>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
        </svg>
      </div>
    </section>


    <!-- ═══════════════════════════════════════════
         WHY DEBBIE'S — FEATURES STRIP
    ════════════════════════════════════════════ -->
    <section class="relative bg-brand-brown py-20 px-4 overflow-hidden">
      <div class="pointer-events-none absolute inset-0 bg-[url('data:image/svg+xml,%3Csvg%20xmlns%3D%22http%3A//www.w3.org/2000/svg%22%20width%3D%2240%22%20height%3D%2240%22%3E%3Ccircle%20cx%3D%2220%22%20cy%3D%2220%22%20r%3D%221%22%20fill%3D%22%23FF6B1A%22%20fill-opacity%3D%220.12%22/%3E%3C/svg%3E')] opacity-60"></div>

      <div class="relative max-w-5xl mx-auto">
        <h2 class="font-display text-center text-3xl sm:text-4xl md:text-5xl text-gradient-fire mb-3">
          Why Dogs Can't Resist Us
        </h2>
        <p class="text-center text-brand-cream/60 mb-14 max-w-xl mx-auto">
          Every bag of Debbie's is packed with tail-wagging goodness — here's what makes us different.
        </p>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
          <!-- Feature 1 -->
          <div class="group flex flex-col items-center text-center bg-white/5 hover:bg-white/10 border border-white/10 hover:border-brand-orange/40 rounded-2xl p-6 transition-all duration-300 hover:-translate-y-1 hover:shadow-2xl cursor-default">
            <div class="text-5xl mb-4 group-hover:animate-bounce-sm">🥩</div>
            <h3 class="font-display text-brand-yellow text-xl mb-2">Real Meat First</h3>
            <p class="text-brand-cream/60 text-sm leading-relaxed">
              Cage-free chicken, wild salmon & grass-fed beef. No fillers, no nonsense.
            </p>
          </div>

          <!-- Feature 2 -->
          <div class="group flex flex-col items-center text-center bg-white/5 hover:bg-white/10 border border-white/10 hover:border-brand-orange/40 rounded-2xl p-6 transition-all duration-300 hover:-translate-y-1 hover:shadow-2xl cursor-default">
            <div class="text-5xl mb-4 group-hover:animate-bounce-sm">🌿</div>
            <h3 class="font-display text-brand-yellow text-xl mb-2">All-Natural Ingredients</h3>
            <p class="text-brand-cream/60 text-sm leading-relaxed">
              Zero artificial colours, flavours or preservatives. Just wholesome goodness.
            </p>
          </div>

          <!-- Feature 3 -->
          <div class="group flex flex-col items-center text-center bg-white/5 hover:bg-white/10 border border-white/10 hover:border-brand-orange/40 rounded-2xl p-6 transition-all duration-300 hover:-translate-y-1 hover:shadow-2xl cursor-default">
            <div class="text-5xl mb-4 group-hover:animate-bounce-sm">🔬</div>
            <h3 class="font-display text-brand-yellow text-xl mb-2">Vet-Formulated</h3>
            <p class="text-brand-cream/60 text-sm leading-relaxed">
              Developed alongside veterinary nutritionists for optimal canine health.
            </p>
          </div>

          <!-- Feature 4 -->
          <div class="group flex flex-col items-center text-center bg-white/5 hover:bg-white/10 border border-white/10 hover:border-brand-orange/40 rounded-2xl p-6 transition-all duration-300 hover:-translate-y-1 hover:shadow-2xl cursor-default">
            <div class="text-5xl mb-4 group-hover:animate-bounce-sm">📦</div>
            <h3 class="font-display text-brand-yellow text-xl mb-2">Delivered to You</h3>
            <p class="text-brand-cream/60 text-sm leading-relaxed">
              Flexible subscriptions with free delivery, straight to your door every month.
            </p>
          </div>
        </div>
      </div>
    </section>


    <!-- ═══════════════════════════════════════════
         SOCIAL PROOF / HYPE NUMBERS
    ════════════════════════════════════════════ -->
    <section class="paw-bg py-20 px-4">
      <div class="max-w-4xl mx-auto text-center">
        <div class="inline-flex items-center gap-2 rounded-full border border-brand-yellow/30 px-4 py-1.5 mb-8 text-brand-yellow/80 text-xs font-extrabold uppercase tracking-widest">
          <span>🔥</span> The Buzz Is Real
        </div>
        <h2 class="font-display text-3xl sm:text-4xl md:text-5xl text-brand-cream mb-16">
          Dogs Already Love Us
        </h2>

        <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 mb-16">
          <div class="flex flex-col items-center gap-1">
            <span class="font-display text-5xl sm:text-6xl text-gradient-fire">8,400+</span>
            <span class="text-brand-cream/60 font-semibold text-sm uppercase tracking-wide">Dogs on the Waitlist</span>
          </div>
          <div class="flex flex-col items-center gap-1">
            <span class="font-display text-5xl sm:text-6xl text-gradient-gold">100%</span>
            <span class="text-brand-cream/60 font-semibold text-sm uppercase tracking-wide">Natural Ingredients</span>
          </div>
          <div class="flex flex-col items-center gap-1">
            <span class="font-display text-5xl sm:text-6xl text-gradient-fire">5 ⭐</span>
            <span class="text-brand-cream/60 font-semibold text-sm uppercase tracking-wide">Beta Taster Rating</span>
          </div>
        </div>

        <!-- Testimonials -->
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-5">
          <!-- T1 -->
          <div class="relative bg-white/5 border border-white/10 rounded-2xl p-6 text-left hover:border-brand-yellow/30 transition-colors duration-300">
            <div class="text-brand-yellow text-lg mb-3">★★★★★</div>
            <p class="text-brand-cream/80 text-sm leading-relaxed mb-4 italic">
              "Biscuit used to be a picky eater. Now she practically knocks the bowl over she's so excited. Unreal."
            </p>
            <div class="flex items-center gap-3">
              <div class="w-9 h-9 rounded-full bg-gradient-to-br from-brand-orange to-brand-red flex items-center justify-center font-display text-white text-sm">S</div>
              <div>
                <p class="text-brand-cream font-bold text-sm">Sarah M.</p>
                <p class="text-brand-cream/40 text-xs">Golden Retriever Mum 🐕</p>
              </div>
            </div>
          </div>

          <!-- T2 -->
          <div class="relative bg-white/5 border border-white/10 rounded-2xl p-6 text-left hover:border-brand-yellow/30 transition-colors duration-300">
            <div class="text-brand-yellow text-lg mb-3">★★★★★</div>
            <p class="text-brand-cream/80 text-sm leading-relaxed mb-4 italic">
              "My vet actually asked what I'd changed. Coat is glossier, energy levels through the roof. Debbie's is it."
            </p>
            <div class="flex items-center gap-3">
              <div class="w-9 h-9 rounded-full bg-gradient-to-br from-brand-yellow to-brand-orange flex items-center justify-center font-display text-brand-darkbrown text-sm">J</div>
              <div>
                <p class="text-brand-cream font-bold text-sm">James T.</p>
                <p class="text-brand-cream/40 text-xs">Beagle Dad 🐶</p>
              </div>
            </div>
          </div>

          <!-- T3 -->
          <div class="relative bg-white/5 border border-white/10 rounded-2xl p-6 text-left hover:border-brand-yellow/30 transition-colors duration-300">
            <div class="text-brand-yellow text-lg mb-3">★★★★★</div>
            <p class="text-brand-cream/80 text-sm leading-relaxed mb-4 italic">
              "Three dogs. Three different breeds. All three obsessed. I've never seen anything like it. Launch already!"
            </p>
            <div class="flex items-center gap-3">
              <div class="w-9 h-9 rounded-full bg-gradient-to-br from-brand-red to-brand-orange flex items-center justify-center font-display text-white text-sm">P</div>
              <div>
                <p class="text-brand-cream font-bold text-sm">Priya K.</p>
                <p class="text-brand-cream/40 text-xs">Multi-dog household 🐾🐾🐾</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- ═══════════════════════════════════════════
         SECOND CTA BANNER
    ════════════════════════════════════════════ -->
    <section class="relative bg-gradient-to-r from-brand-orange via-brand-red to-brand-orange py-16 px-4 overflow-hidden">
      <div class="pointer-events-none absolute inset-0 bg-[url('data:image/svg+xml,%3Csvg%20xmlns%3D%22http%3A//www.w3.org/2000/svg%22%20width%3D%2260%22%20height%3D%2260%22%3E%3Ccircle%20cx%3D%2230%22%20cy%3D%2230%22%20r%3D%222%22%20fill%3D%22%23ffffff%22%20fill-opacity%3D%220.07%22/%3E%3C/svg%3E')]"></div>
      <div class="relative max-w-3xl mx-auto text-center">
        <p class="font-display text-white/80 text-lg sm:text-xl mb-2 tracking-wide">
          Don't let your pup miss out 🐾
        </p>
        <h2 class="font-display text-4xl sm:text-5xl text-white drop-shadow-lg mb-6">
          Join the Waitlist Today
        </h2>
        <p class="text-white/80 text-base sm:text-lg mb-8 max-w-lg mx-auto">
          Early subscribers get <strong class="text-brand-yellow">30% off their first order</strong> and a free bag of our signature training treats.
        </p>
        <a
          href="#signup"
          class="inline-block rounded-2xl bg-brand-darkbrown text-brand-yellow font-display text-xl px-10 py-4 shadow-xl hover:bg-brand-brown hover:scale-105 active:scale-95 transition-all duration-200 focus:outline-none focus:ring-4 focus:ring-brand-yellow/50"
        >
          Sign Me Up! 🐶
        </a>
      </div>
    </section>


    <!-- ═══════════════════════════════════════════
         FOOTER
    ════════════════════════════════════════════ -->
    <footer class="bg-brand-darkbrown border-t border-white/5 py-10 px-4 text-center">
      <div class="flex items-center justify-center gap-2 mb-3">
        <span class="text-2xl">🐾</span>
        <span class="font-display text-brand-orange text-xl">Debbie's Dog Food</span>
        <span class="text-2xl">🐾</span>
      </div>
      <p class="text-brand-cream/40 text-sm mb-1">
        Premium nutrition. Tail-wagging flavours. Launching soon.
      </p>
      <p class="text-brand-cream/25 text-xs">
        © {new Date().getFullYear()} Debbie's Dog Food. All rights reserved. Made with ❤️ for dogs everywhere.
      </p>
    </footer>


    <!-- ═══════════════════════════════════════════
         FORM VALIDATION SCRIPT
    ════════════════════════════════════════════ -->
    <script>
      const form = document.getElementById('signup-form') as HTMLFormElement | null;
      const successMsg = document.getElementById('success-msg');
      const firstNameInput = document.getElementById('firstName') as HTMLInputElement | null;
      const emailInput = document.getElementById('email') as HTMLInputElement | null;
      const firstNameError = document.getElementById('firstName-error');
      const emailError = document.getElementById('email-error');

      function isValidEmail(val: string): boolean {
        return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(val.trim());
      }

      function setError(input: HTMLInputElement, errorEl: HTMLElement | null, show: boolean) {
        if (show) {
          input.classList.add('border-brand-red', 'ring-2', 'ring-brand-red/40');
          input.classList.remove('border-white/15');
          errorEl?.classList.remove('hidden');
        } else {
          input.classList.remove('border-brand-red', 'ring-2', 'ring-brand-red/40');
          errorEl?.classList.add('hidden');
        }
      }

      form?.addEventListener('submit', (e) => {
        e.preventDefault();

        const nameVal  = firstNameInput?.value ?? '';
        const emailVal = emailInput?.value ?? '';
        let valid = true;

        if (nameVal.trim() === '') {
          setError(firstNameInput!, firstNameError, true);
          valid = false;
        } else {
          setError(firstNameInput!, firstNameError, false);
        }

        if (!isValidEmail(emailVal)) {
          setError(emailInput!, emailError, true);
          valid = false;
        } else {
          setError(emailInput!, emailError, false);
        }

        if (valid) {
          form.classList.add('hidden');
          successMsg?.classList.remove('hidden');
          successMsg?.classList.add('flex');
        }
      });

      // Clear errors on input
      firstNameInput?.addEventListener('input', () => {
        if ((firstNameInput?.value ?? '').trim() !== '') {
          setError(firstNameInput!, firstNameError, false);
        }
      });
      emailInput?.addEventListener('input', () => {
        if (isValidEmail(emailInput?.value ?? '')) {
          setError(emailInput!, emailError, false);
        }
      });
    </script>

  </body>
</html>
